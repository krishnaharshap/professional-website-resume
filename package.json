{
  "name": "professional-website-resume",
  "version": "2.0.0",
  "private": true,
  "description": "Static resume site for GitHub Pages, tested with Playwright",
  "scripts": {
    "serve": "serve -l 4173 --no-clipboard .",
    "test": "playwright test",
    "test:chromium": "playwright test --project=chromium",
    "test:links": "playwright test --grep @links --project=chromium",
    "pdf": "node scripts/generate-pdf.mjs"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.0",
    "@playwright/test": "^1.50.0",
    "serve": "^14.2.0"
  }
}
